{
  "name": "all-in-one-discord-bot",
  "version": "1.0.0",
  "description": "Modular all-in-one Discord bot built with TypeScript and discord.js v14.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@discordjs/voice": "^0.18.0",
    "@distube/spotify": "^2.0.2",
    "@distube/yt-dlp": "^2.0.1",
    "discord.js": "^14.16.3",
    "distube": "^5.0.4",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongodb": "^7.1.0",
    "mongoose": "^8.6.2",
    "pino": "^9.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
