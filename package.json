{
  "name": "all-in-one-discord-bot",
  "version": "1.0.0",
  "description": "Modular all-in-one Discord bot built with TypeScript and discord.js v14.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run typecheck && npm run build:bot && npm run activity:build",
    "typecheck": "tsc -p tsconfig.build.json --noEmit && tsc -p activity/tsconfig.json --noEmit",
    "build:bot": "tsc -p tsconfig.build.json",
    "activity:dev": "vite --config activity/vite.config.ts --host 0.0.0.0",
    "activity:build": "vite build --config activity/vite.config.ts",
    "activity:preview": "vite preview --config activity/vite.config.ts --host 0.0.0.0",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:activity:e2e": "node tests/e2e/activityLocal.mjs",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@discord/embedded-app-sdk": "^2.5.0",
    "@discordjs/voice": "^0.19.2",
    "@distube/spotify": "^2.0.2",
    "@distube/youtube": "^1.0.4",
    "@distube/yt-dlp": "^2.0.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@noble/ciphers": "^2.2.0",
    "@tanstack/react-query": "^5.101.2",
    "discord.js": "^14.16.3",
    "distube": "^5.0.4",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "ffmpeg-static": "^5.3.0",
    "helmet": "^8.2.0",
    "lucide-react": "^1.24.0",
    "mongodb": "^7.1.0",
    "mongoose": "^8.6.2",
    "multer": "^2.2.0",
    "music-metadata": "^11.13.0",
    "opusscript": "^0.0.8",
    "pino": "^9.4.0",
    "prism-media": "^1.3.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.7.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "undici@^6.0.0": "6.27.0"
  }
}
